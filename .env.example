# Neon PostgreSQL（pooled endpoint for application）
DATABASE_URL="postgresql://USERNAME:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Neon PostgreSQL（direct endpoint for migrations）
DIRECT_DATABASE_URL="postgresql://USERNAME:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Claude API
ANTHROPIC_API_KEY=

# Auth (Neon Auth + Better Auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
